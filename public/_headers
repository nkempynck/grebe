# Cloudflare Pages security headers — applied to every response.
# Vite copies this file from public/ into dist/ on build.
#
# The CSP is ENFORCING. It was verified in Report-Only mode first (clean console
# on a full run: game, Wikipedia card, leaderboard, Turnstile). If you ever need
# to debug a new violation without blocking users, temporarily rename
# `Content-Security-Policy:` to `Content-Security-Policy-Report-Only:`.
#
# The CSP allowlist covers the only external origins the app actually uses:
#   • Supabase          — auth + RPC/REST            (connect-src *.supabase.co)
#   • Cloudflare Turnstile — captcha script + iframe (script/frame/connect challenges.cloudflare.com)
#   • Wikipedia         — REST summary API           (connect-src en.wikipedia.org)
#                         + lead images              (img-src upload.wikimedia.org, *.wikipedia.org)
# The two inline <script>s in index.html (legacy-domain redirect, then
# theme-before-paint) are each allowed by their own sha256 hash, NOT
# 'unsafe-inline', so injected scripts stay blocked. If either snippet is edited,
# recompute its hash (see the one-liner in git history) or it will be blocked.
# 'unsafe-inline' in style-src is required for React inline style={} attributes.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-PO/pQhqitWhIIx4ClFM7VI1eOVPp/jW60mWSPv7RffI=' 'sha256-pREEHP1tF4hnFjsGWhCxTHPIc2H7oIFfztRnZeIy1s8=' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://upload.wikimedia.org https://*.wikipedia.org; connect-src 'self' https://*.supabase.co https://en.wikipedia.org https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

# Cache strategy (SPA). index.html is the entry point and names the hashed JS/CSS
# bundles; it MUST always be revalidated, or a returning browser keeps an old
# index.html that points at a bundle a later deploy has removed — the request
# then falls back to index.html (text/html), the module script fails its MIME
# check, and the page renders blank until a hard refresh. 'no-cache' means
# "store, but revalidate every time" (cheap 304s), so a new deploy is picked up
# immediately.
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache

# Hashed build assets: the filename changes whenever the content does, so they
# can be cached hard and forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
