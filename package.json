{
  "name": "grebe",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A daily guess-the-organism game played on the tree of life.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:taxonomy": "node scripts/build-taxonomy.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
